{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MonoDB Query Language",
  "scopeName": "source.monodb",
  "fileTypes": ["mql", "monodb"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#string-double" },
    { "include": "#string-single" },
    { "include": "#number" },
    { "include": "#constant" },
    { "include": "#variable" },
    { "include": "#keyword-verb" },
    { "include": "#keyword-clause" },
    { "include": "#keyword-table" },
    { "include": "#keyword-logic" },
    { "include": "#type" },
    { "include": "#constraint" },
    { "include": "#table-type" },
    { "include": "#function" },
    { "include": "#operator" },
    { "include": "#punctuation" },
    { "include": "#identifier" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.double-slash.monodb",
      "match": "//.*$"
    },

    "string-double": {
      "name": "string.quoted.double.monodb",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.monodb" } },
      "endCaptures": { "0": { "name": "punctuation.definition.string.end.monodb" } },
      "patterns": [
        {
          "name": "constant.character.escape.monodb",
          "match": "\\\\[\"\\\\nrt]"
        }
      ]
    },

    "string-single": {
      "name": "string.quoted.single.monodb",
      "begin": "'",
      "end": "'",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.monodb" } },
      "endCaptures": { "0": { "name": "punctuation.definition.string.end.monodb" } },
      "patterns": [
        {
          "name": "constant.character.escape.monodb",
          "match": "\\\\['\\\\nrt]"
        }
      ]
    },

    "number": {
      "patterns": [
        {
          "name": "constant.numeric.float.monodb",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.monodb",
          "match": "\\b\\d+\\b"
        }
      ]
    },

    "constant": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.monodb",
          "match": "\\btrue\\b"
        },
        {
          "name": "constant.language.boolean.false.monodb",
          "match": "\\bfalse\\b"
        },
        {
          "name": "constant.language.null.monodb",
          "match": "\\bnull\\b"
        }
      ]
    },

    "variable": {
      "name": "variable.other.readwrite.monodb",
      "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*"
    },

    "keyword-verb": {
      "name": "keyword.control.monodb",
      "match": "\\b(get|put|change|remove|make)\\b"
    },

    "keyword-clause": {
      "name": "keyword.other.monodb",
      "match": "\\b(from|into|where|with|set|as)\\b"
    },

    "keyword-table": {
      "name": "keyword.other.monodb",
      "match": "\\b(table|fields)\\b"
    },

    "keyword-logic": {
      "name": "keyword.operator.logical.monodb",
      "match": "\\b(and|or|has)\\b"
    },

    "type": {
      "name": "support.type.monodb",
      "match": "\\b(int|bigint|text|decimal|double|date|boolean|map|list|interval)\\b"
    },

    "constraint": {
      "patterns": [
        {
          "name": "storage.modifier.monodb",
          "match": "\\b(primary|key|unique|default|ttl)\\b"
        }
      ]
    },

    "table-type": {
      "name": "entity.name.type.monodb",
      "match": "\\b(relational|document|keyspace)\\b"
    },

    "function": {
      "patterns": [
        {
          "name": "meta.function-call.monodb",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\()",
          "captures": {
            "1": { "name": "entity.name.function.monodb" },
            "2": { "name": "punctuation.section.arguments.begin.monodb" }
          }
        },
        {
          "name": "support.function.builtin.monodb",
          "match": "\\bnow\\b"
        }
      ]
    },

    "operator": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.augmented.monodb",
          "match": "(\\+=|-=)"
        },
        {
          "name": "keyword.operator.comparison.monodb",
          "match": "(!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.monodb",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.monodb",
          "match": "(\\+|-|\\*|/)"
        },
        {
          "name": "keyword.operator.logical.monodb",
          "match": "(\\|\\||\\?\\?)"
        },
        {
          "name": "keyword.operator.pipe.monodb",
          "match": "\\|"
        },
        {
          "name": "keyword.operator.optional.monodb",
          "match": "\\?"
        }
      ]
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.monodb",
          "match": ","
        },
        {
          "name": "punctuation.separator.colon.monodb",
          "match": ":"
        },
        {
          "name": "punctuation.terminator.monodb",
          "match": ";"
        },
        {
          "name": "punctuation.accessor.monodb",
          "match": "\\."
        },
        {
          "name": "punctuation.section.parens.begin.monodb",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.monodb",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.brackets.begin.monodb",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.monodb",
          "match": "\\]"
        },
        {
          "name": "punctuation.section.braces.begin.monodb",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.braces.end.monodb",
          "match": "\\}"
        }
      ]
    },

    "identifier": {
      "name": "variable.other.monodb",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  }
}

